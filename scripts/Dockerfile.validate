# Docker sandbox for Ralph Wiggum Validation
#
# Usage with docker-compose:
#   make validator-up      # Start container
#   make validator-shell   # Enter shell, run: claude /login
#   make validator-down    # Stop when done

FROM golang:1.22-bookworm

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    make \
    jq \
    curl \
    ca-certificates \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user
RUN useradd -m -s /bin/bash validator

# Pre-create .claude directory with correct ownership
RUN mkdir -p /home/validator/.claude && \
    chown -R validator:validator /home/validator/.claude

# Switch to non-root user
USER validator

WORKDIR /workspace

# Default entrypoint for validation
ENTRYPOINT ["./scripts/ralph-validate.sh"]
CMD ["20"]
